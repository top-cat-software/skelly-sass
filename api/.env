APP_ENV=dev
APP_SECRET=skeleton-dev-secret-change-in-production
APP_DEBUG=1

# Database — via PgBouncer in production, direct in dev
DATABASE_URL="postgresql://skelly:skelly-dev-pg-password@localhost:5432/skelly_saas?serverVersion=16&charset=utf8"

# Redis
REDIS_URL="redis://localhost:6379"

# Messenger transport (Redis Streams)
MESSENGER_TRANSPORT_DSN="redis://localhost:6379/messages"
