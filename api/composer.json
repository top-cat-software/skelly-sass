{
    "name": "top-cat-software/skelly-saas-api",
    "description": "skelly-saas API, Auth, and Worker application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/migrations": "^3.9",
        "symfony/console": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/messenger": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/runtime": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "symfony/browser-kit": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/test-pack": "^1.2"
    }
}
